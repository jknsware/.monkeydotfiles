#   templatedir = ~/.git/templates

[alias]

  # List all aliases
  aliases = config --get-regexp alias

  # Custom graph log
  graph = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --date=relative

  # Delete branch
  db = branch -D

  # Show the last commit
  last = log -1 HEAD

  # Create a new branch
  nb = checkout -b

  # Show all remotes for the repo
  remotes = remote -v

  # Rename branch
  renb = branch -m
  

[user]
  name = Jason Ware
  email = jason@jknsware.com
  useconfigonly = true

[filter "lfs"]
  required = true
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process

[commit]
  template = ~/.git/templates/hooks/commit-msg-template

[core]
  editor = sublime -n -w $1:2
  hookspath = ~/.git/templates/hooks
